{% extends 'base.html.twig' %}

{% block title %}Nouvelle adresse{% endblock %}

{% block body %}

    <h1>Ajouter une adresse</h1>

    {{ form_start(form) }}
        {{ form_widget(form) }}
    <button type="submit">Enregistrer</button>
    {% for message in app.flashes('success') %}
        <div class="flash-success">{{ message }}</div>
    {% endfor %}
    {{ form_end(form) }}


{% endblock %}
