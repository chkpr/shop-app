{% extends 'base.html.twig' %}

{% block title %}Tous nos produits{% endblock %}

{% block body %}


<div>
    <h1>Catalogue</h1>

    <ul>
        {% for product in products %}
            <li>{{ product.name }} - {{ product.price }}</li>
         {%  else %}
            <li>Aucun produit pour le moment</li>
         {%  endfor %}
    </ul>
</div>
{% endblock %}
