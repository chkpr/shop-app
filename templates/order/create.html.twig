{% extends 'base.html.twig' %}

{% block title %}Valider ma commande{% endblock %}

{% block body %}
    <h1>Ma commande</h1>

    <h2>Récapitulatif</h2>
    <ul>
        {% for item in items %}
            <li>
                {{ item.product.name }}
                × {{ item.quantity }}
                — {{ (item.product.price / 100)|format_currency('EUR') }}
            </li>
        {% endfor %}
    </ul>
    <p>Total : {{ (total / 100)|format_currency('EUR') }}</p>

    <h2>Adresse de livraison</h2>
    {{ form_start(form) }}
    {{ form_widget(form) }}
    <button type="submit">Commander</button>
    {{ form_end(form) }}
{% endblock %}
